---
const { title = 'Site de démo' } = Astro.props;
---
<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <style>
      :root { font-family: system-ui, sans-serif; color: #211c16; background: #f3eee6; }
      body { margin: 0; }
      main { max-width: 720px; margin: 0 auto; padding: 64px 24px; }
      h1 { font-size: 2.5rem; letter-spacing: -0.02em; }
    </style>
  </head>
  <body>
    <main><slot /></main>
  </body>
</html>
